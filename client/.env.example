# ── AscendPath Client — Environment Variable Template ────────────────
# Copy this to client/.env and fill in your values.

# Backend API base URL (no trailing slash)
# Local:      VITE_API_URL=http://localhost:5000/api/v1
# Production: VITE_API_URL=https://your-backend.onrender.com/api/v1
VITE_API_URL=http://localhost:5000/api/v1
